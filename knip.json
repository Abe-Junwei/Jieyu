    "src/pages/transcriptionReadyWorkspaceTimelineInteractionInputBuilder.ts": ["exports"],
    "src/pages/transcriptionTimelineWorkspacePanelTypes.ts": ["exports"],
    "src/services/languageCatalog/languageCatalogCoreNormalization.ts": ["exports"],
    "src/services/VoiceAgentService.lifecycle.ts": ["exports"],
    "src/services/VoiceInputService.probes.ts": ["exports"],
    "src/services/VoiceInputService.ts": ["exports"],
    "src/services/VoiceInputService.webSpeechSupport.ts": ["exports"],
    "src/utils/orthographyRuntime.ts": ["exports"],
    "src/utils/transcriptionUnitLaneReadScope.ts": ["types"],
    "src/workerThreads.browser.ts": ["exports"]
