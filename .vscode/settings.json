{
    "deepseek.apiKey": "${env:DEEPSEEK_API_KEY}",
    "claudeCode.preferredLocation": "sidebar",
    "workbench.browser.enableChatTools": true,
    "eslint.validate": [
        "javascript",
        "javascriptreact",
        "typescript",
        "typescriptreact"
    ],
    "editor.codeActionsOnSave": {
        "source.fixAll.eslint": "explicit"
    }
}