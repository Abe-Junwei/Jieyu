{
  "mcpServers": {
    "openspace": {
      "command": "openspace-mcp",
      "toolTimeout": 600,
      "env": {
        "OPENSPACE_HOST_SKILL_DIRS": "/absolute/path/to/agent/skills",
        "OPENSPACE_WORKSPACE": "/absolute/path/to/OpenSpace",
        "OPENSPACE_API_KEY": "<optional-api-key>"
      }
    }
  }
}
