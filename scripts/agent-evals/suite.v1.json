{
  "suiteId": "jieyu-agent-evals-v1",
  "version": 1,
  "description": "Golden-path agent governance regression suite. Cases tagged `tier: smoke` are the L1 pre-merge subset (≤ ~90s) covering the 3 typical AI mistake categories: 错读路径 / 业务逻辑落到编排层 / UI 文案落到 src/ai/messages/. All other cases default to `tier: full` and run via `check:agent-evals` / `:trace`.",
  "thresholds": {
    "requiredPassRate": 0.9,
    "maxFailedCases": 0,
    "requiredGoldenTasksMin": 30,
    "requiredTrajectorySignals": [
      "tool_selection",
      "gate_correctness",
      "recovery_path",
      "audit_traceability",
      "approval_explainability"
    ]
  },
  "tierThresholds": {
    "smoke": {
      "requiredPassRate": 1.0,
      "maxFailedCases": 0,
      "requiredGoldenTasksMin": 0,
      "requiredTrajectorySignals": []
    }
  },
  "cases": [
    {
      "id": "typecheck",
      "name": "TypeScript typecheck (smoke: catches 错读路径 via broken imports)",
      "command": "npm run typecheck",
      "category": "build",
      "tiers": ["smoke", "full"],
      "goldenTaskCount": 0,
      "trajectorySignals": []
    },
    {
      "id": "architecture-guard-core",
      "name": "architecture-guard core (smoke: catches 业务逻辑落到编排层)",
      "command": "npm run check:architecture-guard:core",
      "category": "structure",
      "tiers": ["smoke", "full"],
      "goldenTaskCount": 0,
      "trajectorySignals": []
    },
    {
      "id": "ai-messages-isolation",
      "name": "src/ai/messages 与 i18n dictKeys 分层 (smoke: UI 文案 vs formatter 文案分层)",
      "command": "node scripts/check-ai-messages-isolation.mjs",
      "category": "policy",
      "tiers": ["smoke", "full"],
      "goldenTaskCount": 0,
      "trajectorySignals": []
    },
    {
      "id": "directive-governance",
      "name": "Directive governance tests",
      "command": "npx vitest run src/ai/memory/userDirectiveExtractor.test.ts src/hooks/ai/useAiChat.responsePolicy.test.ts src/hooks/ai/useAiChat.backgroundMemory.test.ts src/hooks/ai/useAiChat.toolDecisionPipeline.test.ts",
      "category": "policy",
      "goldenTaskCount": 10,
      "trajectorySignals": [
        "tool_selection",
        "gate_correctness",
        "audit_traceability"
      ]
    },
    {
      "id": "prompt-memory",
      "name": "Prompt and memory integration tests",
      "command": "npx vitest run src/ai/chat/sessionMemory.test.ts src/ai/chat/promptContext.tiered.test.ts src/hooks/ai/useAiChat.streamCompletion.test.ts src/hooks/ai/useAiChat.agentLoopRunner.test.ts",
      "category": "runtime",
      "goldenTaskCount": 8,
      "trajectorySignals": [
        "tool_selection",
        "recovery_path"
      ]
    },
    {
