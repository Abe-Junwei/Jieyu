{
  "name": "jieyu",
  "version": "1.0.0",
  "description": "解语 (Jieyu) — 濒危语言科研协作平台",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "data:language-seeds": "node scripts/generate-language-orthography-seeds.mjs",
    "data:language-seeds:expand": "node scripts/expand-language-orthography-seeds.mjs",
    "data:language-seeds:validate-independent": "node scripts/validate-language-orthography-independent.mjs",
    "data:language-seeds:converge-main-map-to-mnk": "node scripts/converge-language-orthography-seeds-main.mjs",
    "data:language-seeds:remediate": "node scripts/remediate-language-orthography-seeds.mjs",
    "data:language-seeds:validate-independent:whitelist": "LANGUAGE_SEEDS_INPUT=public/data/language-support/top500-language-orthography-seeds.publish-whitelist.json LANGUAGE_SEEDS_VALIDATION_REPORT=public/data/language-support/orthography-independent-validation-report.publish-whitelist.json node scripts/validate-language-orthography-independent.mjs",
    "data:language-seeds:publish-variant:map-to-mnk": "node scripts/build-publish-variant-map-to-mnk.mjs",
    "data:language-seeds:validate-independent:publish-variant:map-to-mnk": "LANGUAGE_SEEDS_INPUT=public/data/language-support/top500-language-orthography-seeds.publish-whitelist.map-to-mnk.json LANGUAGE_SEEDS_VALIDATION_REPORT=public/data/language-support/orthography-independent-validation-report.publish-whitelist.map-to-mnk.json node scripts/validate-language-orthography-independent.mjs",
    "data:language-catalog:baseline": "node scripts/generate-language-name-indexes.mjs",
    "data:language-name-indexes": "node scripts/generate-language-name-indexes.mjs",
    "acoustic:calibrate": "node scripts/evaluate-acoustic-calibration.mjs",
    "typecheck": "tsc --noEmit",
    "check:css": "node scripts/check-css.cjs",
    "check:css-class-contract": "node scripts/check-css-class-contract.mjs",
    "check:css-class-contract:write-baseline": "node scripts/check-css-class-contract.mjs --write-baseline",
    "check:css-inline-style": "node scripts/check-css-inline-style.mjs",
    "check:css-inline-style:write-baseline": "node scripts/check-css-inline-style.mjs --write-baseline",
    "check:css-token-usage": "node scripts/check-css-token-usage.mjs",
    "check:css-token-usage:write-baseline": "node scripts/check-css-token-usage.mjs --write-baseline",
    "check:css-token-governance": "npm run check:css-token-usage",
    "check:css-dup-selectors": "node scripts/check-css-dup-selectors.mjs",
    "check:css-dup-selectors:write-baseline": "node scripts/check-css-dup-selectors.mjs --write-baseline",
    "check:css-layer-boundary": "node scripts/check-css-layer-boundary.mjs",
    "check:css-motion-accessibility": "node scripts/check-css-motion-accessibility.mjs",
    "check:css-a11y": "node scripts/check-css-a11y.mjs",
    "check:css-a11y:write-baseline": "node scripts/check-css-a11y.mjs --write-baseline",
    "check:css-compat": "node scripts/check-css-compat.mjs",
    "check:css-naming-convention": "node scripts/check-css-naming-convention.mjs",
    "check:css-naming-convention:write-baseline": "node scripts/check-css-naming-convention.mjs --write-baseline",
    "check:css-unused-selectors": "node scripts/check-css-unused-selectors.mjs",
    "check:css-unused-selectors:write-baseline": "node scripts/check-css-unused-selectors.mjs --write-baseline",
    "check:css-deprecation-window": "node scripts/check-css-deprecation-window.mjs",
    "lint:css": "stylelint \"src/styles/**/*.css\"",
    "test:visual-css": "node scripts/test-visual-css-baseline.mjs",
    "test:visual-css:write-baseline": "node scripts/test-visual-css-baseline.mjs --write-baseline",
    "check:css-architecture": "npm run check:css-inline-style && npm run check:css-token-usage && npm run check:css-dup-selectors && npm run check:css-layer-boundary && npm run check:css-motion-accessibility && npm run check:css-compat",
    "check:dialog-style-guard": "node scripts/check-dialog-style-guard.mjs",
    "check:panel-foundation": "npm run check:dialog-style-guard && npm run check:css-layer-boundary && npm run check:architecture-guard",
    "check:panel-shared-purity:phase1": "node scripts/check-panel-shared-purity-phase1.mjs",
    "check:i18n-hardcoded": "node scripts/check-i18n-hardcoded.cjs",
    "check:i18n-hardcoded:summary": "node scripts/check-i18n-hardcoded.cjs --summary-only",
    "check:i18n-hardcoded:changed": "node scripts/check-i18n-hardcoded.cjs --changed-only --summary-only",
    "check:i18n-hardcoded:thresholds": "node scripts/check-i18n-hardcoded.cjs --summary-only --baseline=scripts/i18n-hardcoded-baseline.json --threshold-config=scripts/i18n-hardcoded-thresholds.json",
    "check:i18n-hardcoded:guard": "node scripts/check-i18n-hardcoded.cjs --strict --baseline=scripts/i18n-hardcoded-baseline.json --threshold-config=scripts/i18n-hardcoded-thresholds.json",
    "check:i18n-hardcoded:write-baseline": "node scripts/check-i18n-hardcoded.cjs --summary-only --write-baseline --baseline=scripts/i18n-hardcoded-baseline.json",
    "check:locale-usage": "node scripts/check-locale-usage.mjs",
    "check:docs-governance": "node scripts/check-docs-governance.mjs",
    "report:docs-link-debt": "node scripts/check-docs-governance.mjs --all-links --report-only",
    "github:branch-protection:dry-run": "node scripts/configure-github-branch-protection.mjs --dry-run",
    "github:branch-protection:apply": "node scripts/configure-github-branch-protection.mjs",
    "check:architecture-guard": "node scripts/check-architecture-guard.mjs",
    "report:architecture-hotspots": "node scripts/check-architecture-guard.mjs --report",
    "check:messages-imports": "node scripts/check-message-imports.mjs",
    "check:segmentation-storage-boundary": "node scripts/check-segmentation-storage-boundary.mjs",
    "check:tier-boundary-imports": "node scripts/check-tier-boundary-imports.mjs",
    "report:tierid-diffusion": "node scripts/report-tierid-diffusion.mjs",
    "check:tierid-diffusion": "node scripts/report-tierid-diffusion.mjs --strict --max-off-boundary=0",
    "audit:prod": "npm audit --omit=dev",
    "audit:prod:json": "npm audit --omit=dev --json",
    "test:timeline-regression": "vitest run src/pages/TranscriptionPage.layoutGuard.test.ts src/components/TimelineLaneHeader.test.tsx src/components/TranscriptionTimelineMediaLanes.test.tsx src/components/TranscriptionTimelineTextOnly.test.tsx",
    "gate:timeline-phase1": "npm run check:architecture-guard && npm run test:timeline-regression && npm run build",
    "test:panel-regression": "vitest run src/components/AiAnalysisPanel.test.tsx src/components/AudioImportDialog.test.tsx src/components/ConfirmDeleteDialog.test.tsx src/components/LayerManagerPopover.test.tsx src/components/NotePanel.test.tsx src/components/PdfViewerPanel.test.tsx src/components/ShortcutsPanel.test.tsx src/components/SidePaneSidebarSpeakerManagement.test.tsx src/components/transcription/LeftRailProjectHub.test.tsx src/components/transcription/RegionActionOverlay.test.tsx src/components/transcription/SpeakerActionDialog.test.tsx src/components/transcription/toolbar/UndoHistory.test.tsx src/components/ai/AiChatCard.input.test.tsx src/components/ai/AiChatMetricsBar.test.tsx src/components/ai/AiEmbeddingCard.test.tsx src/components/ai/AiComplexPanels.rtlMatrix.test.tsx",
    "gate:panel-phase1": "npm run check:panel-foundation && npm run check:css-architecture && npm run test:panel-regression",
    "test": "npm run check:css && npm run lint:css && npm run check:css-class-contract && npm run check:css-architecture && npm run check:css-a11y && npm run check:css-naming-convention && npm run check:css-unused-selectors && npm run check:css-deprecation-window && npm run test:visual-css && npm run check:messages-imports && npm run check:locale-usage && npm run check:docs-governance && npm run check:dialog-style-guard && npm run check:i18n-hardcoded:guard && npm run check:segmentation-storage-boundary && npm run check:tier-boundary-imports && npm run check:tierid-diffusion && npm run check:architecture-guard && vitest run",
    "check:build-budgets": "node scripts/check-build-budgets.mjs",
    "profile:build-assets": "node scripts/profile-build-assets.mjs",
    "build:profile": "npm run build && npm run profile:build-assets",
    "build:guard": "npm run build && npm run profile:build-assets && npm run check:build-budgets && npm run audit:prod",
    "validate": "npm run typecheck && npm run test && npm run build:guard",
    "perf:ai": "vitest run src/ai/perf/AiPerformanceBaseline.test.tsx --reporter=verbose",
    "perf:track": "vitest run src/perf/TrackLayoutPerformanceBaseline.test.ts --reporter=verbose",
    "perf:embedding-candidates": "vitest run src/ai/perf/EmbeddingCandidateSetPerformanceBaseline.test.ts --reporter=verbose",
    "perf:embedding-model-ab:real": "JIEYU_REAL_EMBEDDING_AB=1 vitest run src/ai/perf/EmbeddingModelABTest.test.ts --reporter=verbose",
    "perf:timestamp-eval": "vitest run src/ai/perf/timestampEvalUtils.test.ts --reporter=verbose",
    "test:coverage": "vitest run --coverage",
    "data:download-distil-whisper": "bash scripts/download-distil-whisper.sh",
    "scaffold:ui-surface": "node scripts/scaffold-ui-surface.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@huggingface/transformers": "^4.0.1",
